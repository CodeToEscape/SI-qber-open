def inject_storage_corruption(bits, cycles, T2=25.0, base_error_rate=0.02):
    """Realistic quantum memory decay: P(error) = 1 - exp(-t/T2)"""
    p_error = 1 - np.exp(-cycles / T2)
    corrupted_bits = bits.copy()
    
    for i in range(len(bits)):
        if np.random.random() < base_error_rate + p_error * (i / len(bits)):
            corrupted_bits[i] = 1 - bits[i]
    
    error_pattern = ''.join(map(str, corrupted_bits ^ bits))
    fingerprint = hashlib.md5(error_pattern.encode()).hexdigest()
    
    return corrupted_bits, p_error, fingerprint
