def smra_path_score(path, predictor):
    """Integrate into SDN routing"""
    predicted_storage = predictor.predict(path.storage_cycles)
    corrected_qber = max(0, path.observed_qber - predicted_storage)
    
    # SMRA weights: quality(40%), trust(30%), freshness(20%), penalty(10%)
    quality = 1.0 / (1 + corrected_qber)
    score = (0.4 * quality + 0.3 * path.trust + 
             0.2 * path.freshness - 0.1 * path.penalty)
    
    return score, corrected_qber
